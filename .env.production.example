# Production overrides — merge into .env on the server (do not commit .env)
NODE_ENV=production

API_SERVER_NAME=logiapi.slash.sa
API_PUBLIC_URL=https://logiapi.slash.sa
CORS_ORIGINS=https://logiadmin.slash.sa

SKIP_PRISMA_GENERATE=true
RUN_DB_SEED=false

SMS_NOTIFICATIONS_ENABLED=true

# Worker / pool (match docker-compose.prod.yml)
PG_POOL_MAX=10
DB_CONCURRENCY=5
CRON_STARTUP_DELAY_MS=45000
SMS_WORKER_CONCURRENCY=3
