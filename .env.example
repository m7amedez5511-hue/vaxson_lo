# =============================================================================
# Logistics App — environment template
# Copy to .env and fill in secrets. Never commit .env
#
# Development:
#   cp .env.example .env
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build
#
# Production:
#   cp .env.example .env
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
# =============================================================================

# --- Runtime ---
NODE_ENV=development
PORT=3000

# --- Public URLs (used by nginx / CORS) ---
API_SERVER_NAME=localhost
API_PUBLIC_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Startup flags (start.sh) ---
# Production images already run `prisma generate` at build time.
SKIP_PRISMA_GENERATE=false
# Only seed on first dev setup or when explicitly enabled in production.
RUN_DB_SEED=true

# --- Postgres ---
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://logistic_app:change_me_strong_password@postgres:5432/logistic_app
PGWEB_DATABASE_URL=postgresql://logistic_app:change_me_strong_password@postgres:5432/logistic_app?sslmode=disable

# --- Redis (BullMQ / cron) ---
REDIS_URL=redis://redis:6379

# --- MongoDB ---
MONGO_USERNAME=logistic_app
MONGO_PASSWORD=change_me_mongo_password
MONGODB_URI=mongodb://logistic_app:change_me_mongo_password@mongo:27017/logistic_app?authSource=admin

# --- Admin DB tools (dev only — disable in production compose) ---
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=change_me
PGWEB_AUTH_USER=admin
PGWEB_AUTH_PASS=change_me

# --- JWT ---
ACCESS_TOKEN_SECRET=change_me_access_secret_min_32_chars
REFRESH_TOKEN_SECRET=change_me_refresh_secret_min_32_chars
TOKEN_PREFIX=Bearer

# --- SMS (Jawaly) ---
JAWALY_BASE_URL=https://api-sms.4jawaly.com/api/v1
JAWALY_API_KEY=
JAWALY_API_SECRET=
SMS_SENDER=SLASHco
SMS_NOTIFICATIONS_ENABLED=false
FLEET_MANAGER_PHONE=

# --- Notification policy ---
ALERT_MONTHS=3
POST_EXPIRY_DAYS=45
MAINT_ALERT_DAYS=7

# --- Connection pool / worker tuning ---
PG_POOL_MAX=10
PG_POOL_IDLE_MS=30000
PG_POOL_CONNECT_MS=5000
DB_CONCURRENCY=5
CRON_STARTUP_DELAY_MS=45000
CRON_RUN_ON_STARTUP=true
SMS_WORKER_CONCURRENCY=3

# --- Seed (initial admin — first run only) ---
INITIAL_ADMIN_USERNAME=slash_admin
INITIAL_ADMIN_PASSWORD=change_me
INITIAL_ADMIN_PHONE=+966500000000
INITIAL_ADMIN_EMAIL=admin@slash.sa

# --- Nginx upstream (internal Docker service name) ---
API_UPSTREAM_HOST=logistic-app

# --- Production overrides (uncomment on server) ---
 NODE_ENV=production
 API_SERVER_NAME=logiapi.slash.sa
 API_PUBLIC_URL=https://logiapi.slash.sa
 CORS_ORIGINS=https://logiadmin.slash.sa
 SKIP_PRISMA_GENERATE=true
 RUN_DB_SEED=false
 SMS_NOTIFICATIONS_ENABLED=true
